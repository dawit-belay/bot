generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  telegramId  BigInt       @id
  username    String?
  name        String
  balance     Int          @default(100)
  wins        Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  deposits    Deposit[]
  gamePlayers GamePlayer[]
}

model Deposit {
  id        BigInt   @id @default(autoincrement())
  userId    BigInt
  amount    Int
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [telegramId], onDelete: Cascade)

  @@index([userId])
}

model Cartela {
  id          Int          @id @default(autoincrement())
  numbers     Json
  createdAt   DateTime     @default(now())
  gamePlayers GamePlayer[]
}

model Game {
  id            Int          @id @default(autoincrement())
  status        String       @default("waiting")
  countdown     Int?
  totalPool     Int          @default(0)
  houseCut      Int          @default(0)
  winnerAmount  Int?
  winnerId      BigInt?
  winners       Json         @default("[]")
  calledNumbers Json         @default("[]")
  playerCount   Int          @default(0)
  message       String?
  createdAt     DateTime     @default(now())
  startedAt     DateTime?
  finishedAt    DateTime?
  gamePlayers   GamePlayer[]

  @@index([status])
}

model GamePlayer {
  id        BigInt   @id @default(autoincrement())
  userId    BigInt
  gameId    Int
  cartelaId Int
  joinedAt  DateTime @default(now())
  cartela   Cartela  @relation(fields: [cartelaId], references: [id], onDelete: Cascade)
  game      Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [telegramId], onDelete: Cascade)

  @@unique([gameId, userId])
  @@unique([gameId, cartelaId])
  @@index([gameId])
  @@index([userId])
}
